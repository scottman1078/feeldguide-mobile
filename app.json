{
  "expo": {
    "name": "FeeldGuide",
    "slug": "feeldguide-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "feeldguide",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.feeldguide.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.feeldguide.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#2AA198"
        }
      ]
    ],
    "notification": {
      "iosDisplayInForeground": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ad50c5bb-2918-4448-a9f9-a8c72bcd348e"
      }
    },
    "owner": "scottman77",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ad50c5bb-2918-4448-a9f9-a8c72bcd348e"
    }
  }
}
